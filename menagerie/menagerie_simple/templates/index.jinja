<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="description" content="Menagerie">
    <meta name="keywords" content="flask, jinja, html">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.colors.min.css">
    <link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}">
    <title>Menagerie</title>
</head>

<body>
    <header class="container">
        <nav>
            <ul>
                <a href='{{ url_for("main.index") }}'>Menagerie adoption center 🦝</a>
            </ul>
            <ul>
                {% if "current_user" in session %}
                    <li>Hi {{ session["current_user"]["name"] }}!</li>
                    <li>
                        <a href='{{ url_for("main.profile") }}'>Profile</a>
                    </li>
                    <li>
                        <a href='{{ url_for("auth.logout") }}'>Log out</a>
                    </li>
                {% else %}
                    <li>
                        <a href='{{ url_for("auth.signup") }}'>Sign up</a>
                    </li>
                    <li>
                        <a href='{{ url_for("auth.login") }}'>Log in</a>
                    </li>
                {% endif %}
            </ul>
        </nav>
    </header>
    <main class="container">
        {% block content %}
            <section id="animals">
                <table class="striped">
                    <thead>
                        <th>Name</th>
                        <th>Age</th>
                        <th>Species</th>
                        <th>Location</th>
                        {% if "current_user" in session %}
                            <th>Decision</th>
                        {% else %}
                            <th>Popularity</th>
                        {% endif %}
                    </thead>
                    <tbody>
                        {% for item in data %}
                            <tr>
                                <td>{{ item.name }}</td>
                                <td>{{ item.age }}</td>
                                <td>{{ item.species }}</td>
                                {% if "current_user" in session %}
                                    <td>{{ item.location }}</td>
                                    <td>
                                        <form method="post" action="{{ url_for('main.adopt', animal_id=item.id) }}"
                                            class="small-button">
                                            <div role="group">
                                                <input type="submit" name="adopt" value="Adopt" class="primary"
                                                    {% if item.id in adopted %}disabled{% endif %} />
                                                <input type="submit" name="reject" value="Reject" class="pico-background-pink-600"
                                                    {% if item.id not in adopted %}disabled{% endif %} />
                                            </div>
                                        </form>
                                    </td>
                                {% else %}
                                    <td>{{ "*" * item.location|length }}</td>
                                    <td>{{ "❤️" * admired.get(item.id, 0) }}</td>
                                {% endif %}
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </section>
        {% endblock content %}
    </main>
    <footer class="container">
        {% for category, msg in get_flashed_messages(with_categories=true) %}
            <p class="{{ category }}">{{ msg }}</p>
        {% endfor %}
    </footer>
</body>

</html>